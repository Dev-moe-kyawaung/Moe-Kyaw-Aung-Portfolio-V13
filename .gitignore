# ============================================================
# .gitignore — Moe Kyaw Aung Portfolio V13
# ============================================================

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Editor directories and files
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*~

# Node (if local server used)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# Python
__pycache__/
*.py[cod]
*.pyo

# Local environment
.env
.env.local
.env.*.local

# Build artifacts
dist/
build/
*.tmp
*.temp
*.log

# Archives
*.zip
*.tar
*.tar.gz
*.rar

# Keep assets folder
!assets/.gitkeep
